{
  "name": "@lostcoords/lumi-reader-core",
  "version": "0.1.0",
  "description": "Framework-agnostic EPUB reader engine: atom-offset positioning, highlight anchoring, neutral store, injected ports",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "sideEffects": false,
  "license": "MIT",
  "author": "xyaman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xyaman/lumi.git",
    "directory": "packages/reader-core"
  },
  "homepage": "https://github.com/xyaman/lumi#readme",
  "bugs": "https://github.com/xyaman/lumi/issues",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --conditions development --test test/*.test.ts",
    "test:watch": "tsx --conditions development --test --watch test/*.test.ts"
  },
  "dependencies": {
    "@lostcoords/lumi-epub": "workspace:*"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^15.11.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
