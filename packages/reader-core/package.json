{
  "name": "@lumi/reader-core",
  "version": "0.0.0",
  "private": true,
  "description": "Framework-agnostic EPUB reader engine: atom-offset positioning, highlight anchoring, neutral store, injected ports",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["dist", "src"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts",
    "test:watch": "tsx --test --watch test/*.test.ts"
  },
  "dependencies": {
    "@lumi/epub": "workspace:*"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^15.11.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
