{
  "name": "@lostcoords/lumi-reader-react",
  "version": "0.1.0",
  "description": "React 19 wrapper for @lostcoords/lumi-reader-core: mounts the reader engine and bridges the neutral store + SettingsPort to hooks",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "sideEffects": false,
  "license": "MIT",
  "author": "xyaman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xyaman/lumi.git",
    "directory": "packages/reader-react"
  },
  "homepage": "https://github.com/xyaman/lumi#readme",
  "bugs": "https://github.com/xyaman/lumi/issues",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --conditions development --test test/*.test.ts test/*.test.tsx"
  },
  "dependencies": {
    "@lostcoords/lumi-epub": "workspace:*",
    "@lostcoords/lumi-reader-core": "workspace:*",
    "use-sync-external-store": "^1.6.0"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^15.11.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/use-sync-external-store": "^1.5.0",
    "react": "^19",
    "react-dom": "^19",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
