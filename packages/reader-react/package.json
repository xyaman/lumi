{
  "name": "@lumi/reader-react",
  "version": "0.0.0",
  "private": true,
  "description": "React 19 wrapper for @lumi/reader-core: mounts the reader engine and bridges the neutral store + SettingsPort to hooks",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["src"],
  "sideEffects": false,
  "scripts": {
    "build": "echo 'reader-react is consumed from source (no build step during pre-release)'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --tsconfig tsconfig.json --test test/*.test.ts test/*.test.tsx"
  },
  "dependencies": {
    "@lumi/epub": "workspace:*",
    "@lumi/reader-core": "workspace:*",
    "use-sync-external-store": "^1.6.0"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^15.11.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/use-sync-external-store": "^1.5.0",
    "react": "^19",
    "react-dom": "^19",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
